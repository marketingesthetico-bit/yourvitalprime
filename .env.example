# ============================================================
# YourVitalPrime — Environment Variables Template
# Copy to .env.local and fill in values. NEVER COMMIT .env.local
# ============================================================

# ── AI Models ────────────────────────────────────────────────
ANTHROPIC_API_KEY=                     # Claude Sonnet — article writing + humanizing
OPENAI_API_KEY=                        # GPT-4o-mini (keyword/competitor agents) + DALL-E 3 (images)

# ── Firebase ─────────────────────────────────────────────────
FIREBASE_PROJECT_ID=yourvitalprime
FIREBASE_CLIENT_EMAIL=                 # From Firebase service account JSON
FIREBASE_PRIVATE_KEY=                  # From Firebase service account JSON (include \n)

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=yourvitalprime.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=yourvitalprime
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=yourvitalprime.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Google APIs ───────────────────────────────────────────────
# Service account for Google Search Console Indexing API
# Download JSON from Google Cloud Console → IAM → Service Accounts
# Grant "Owner" in GSC → Settings → Users and permissions
GOOGLE_SERVICE_ACCOUNT_KEY=            # Full JSON as string (escape quotes)
GSC_SITE_URL=https://yourvitalprime.com

# ── SERP / Keyword Research ───────────────────────────────────
# Option A: SerpAPI (easier setup, $50/month for 5000 searches)
SERPAPI_KEY=

# Option B: DataForSEO (cheaper at scale, pay-per-use)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ── Image Generation ──────────────────────────────────────────
# Stability AI for inline article images (cheaper than DALL-E for high volume)
STABILITY_API_KEY=
# DALL-E 3 uses the OPENAI_API_KEY above

# ── Security ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
CRON_SECRET=

# ── Analytics ─────────────────────────────────────────────────
NEXT_PUBLIC_GA4_MEASUREMENT_ID=        # G-XXXXXXXXXX

# ── AdSense (add AFTER approval) ──────────────────────────────
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=      # ca-pub-XXXXXXXXXX

# ── Email (Newsletter — Phase 6) ──────────────────────────────
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=
